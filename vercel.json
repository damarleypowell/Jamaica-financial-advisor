{
  "version": 2,
  "buildCommand": "cd jamaica-financial-advisor/frontend && npm install && npm run build",
  "outputDirectory": "jamaica-financial-advisor/frontend/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "jamaica-financial-advisor/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*",  "destination": "/api/index.js" },
    { "source": "/health",      "destination": "/api/index.js" },
    { "source": "/analyze",     "destination": "/api/index.js" },
    { "source": "/:path*",      "destination": "/index.html" }
  ]
}
